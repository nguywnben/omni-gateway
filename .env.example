# Omni Gateway environment configuration example
# Copy this file to .env and adjust values for your deployment.

# Server
OGW_HOST=0.0.0.0
OGW_PORT=7861

# Authentication
# OGW_PASSWORD is the simple single-secret mode. For separated access, set
# OGW_API_PASSWORD and OGW_PANEL_PASSWORD instead.
OGW_PASSWORD=pwd
# OGW_API_PASSWORD=your_api_password
# OGW_PANEL_PASSWORD=your_panel_password

# Storage
# Default storage uses local files under OGW_CREDENTIALS_DIR. Set one of the
# external storage URIs below when running multiple instances.
OGW_CREDENTIALS_DIR=./backend/data/creds
OGW_MONGODB_URI=
OGW_MONGODB_DATABASE=omni_gateway
OGW_POSTGRESQL_URI=
OGW_REDIS_URL=

# Optional environment credential import.
# Paste raw JSON or use the *_B64 variants for base64-encoded JSON.
# OGW_CODE_ASSIST_CREDENTIALS_JSON={"token":"...","refresh_token":"...","client_id":"...","client_secret":"...","project_id":"..."}
# OGW_CREDENTIALS_JSON={"token":"...","refresh_token":"...","client_id":"...","client_secret":"...","project_id":"..."}

# OAuth client configuration for interactive credential creation.
# Required when using the OAuth flows in the control panel.
# OGW_CODE_ASSIST_CLIENT_ID=
# OGW_CODE_ASSIST_CLIENT_SECRET=
# OGW_CLIENT_ID=
# OGW_CLIENT_SECRET=
# OGW_USER_AGENT=omni-gateway/cli/1.0.1 windows/amd64

# Network and upstream endpoints
OGW_PROXY=
OGW_CODE_ASSIST_ENDPOINT=https://cloudcode-pa.googleapis.com
OGW_API_URL=https://daily-cloudcode-pa.googleapis.com
OGW_OAUTH_URL=https://oauth2.googleapis.com
OGW_GOOGLE_APIS_URL=https://www.googleapis.com
OGW_RESOURCE_MANAGER_URL=https://cloudresourcemanager.googleapis.com
OGW_SERVICE_USAGE_URL=https://serviceusage.googleapis.com
# Required only when enabling Vertex anonymous routing.
OGW_VERTEX_ANON_API_KEY=

# Fallback, retry, and health behavior
OGW_AUTO_DISABLE=false
OGW_AUTO_DISABLE_ERROR_CODES=403
OGW_RETRY_429_ENABLED=true
OGW_RETRY_429_MAX_RETRIES=5
OGW_RETRY_429_INTERVAL=1
OGW_SWITCH_CREDENTIAL_ENABLED=false

# Translation and response shaping
OGW_COMPATIBILITY_MODE=false
OGW_RETURN_THOUGHTS_TO_FRONTEND=true
OGW_STREAM_TO_NONSTREAM=true
OGW_ANTI_TRUNCATION_MAX_ATTEMPTS=3

# Observability
OGW_LOG_LEVEL=info
OGW_LOG_FILE=./backend/data/logs/omni-gateway.log

# Optional keep-alive ping for platforms that suspend idle services.
OGW_KEEPALIVE_URL=
OGW_KEEPALIVE_INTERVAL=60
