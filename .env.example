# Omni Gateway environment configuration example
# Copy this file to .env and adjust values for your deployment.

# Server
HOST=0.0.0.0
PORT=4283
# Docker Compose host-side port. It does not change the application listener.
HOST_PORT=4283
# Omni Gateway 1.x supports exactly one application worker and replica.
# Shared storage does not yet coordinate reservations, cooldowns, or usage state.
WORKERS=1
# Comma-separated browser origins allowed to call the API from another origin.
# Leave empty for same-origin console usage. Use explicit origins in production.
CORS_ORIGINS=
CORS_ORIGIN_REGEX=

# Authentication
# Leave password variables empty on first run to use the web setup screen.
# After setup, Omni Gateway stores the password in its configured storage.
# For non-interactive deployments, set PANEL_PASSWORD.
# Public client integrations should use an API key with the sk-ogw- prefix.
# API_KEY=sk-ogw-change-me
# PANEL_PASSWORD=your_panel_password
# Optional fixed token for first-time setup from a remote browser. When omitted,
# Omni Gateway prints an ephemeral setup token to the application logs.
# SETUP_TOKEN=replace-with-a-long-random-value
PANEL_SESSION_TTL_SECONDS=86400
# Leave empty for automatic HTTPS detection through X-Forwarded-Proto. Set to
# true to require secure cookies, or false only for a deliberately HTTP-only host.
PANEL_COOKIE_SECURE=
PANEL_LOGIN_WINDOW_SECONDS=300
PANEL_LOGIN_MAX_ATTEMPTS=10
# Bound the in-memory login limiter when exposed to many distinct client addresses.
PANEL_LOGIN_MAX_TRACKED_CLIENTS=10000
# Reject oversized fixed-length and chunked HTTP request bodies.
MAX_REQUEST_BODY_MB=64
# Enable only behind a trusted reverse proxy that overwrites forwarded headers.
TRUST_PROXY_HEADERS=false

# Storage
# Single-instance storage uses local files under CREDENTIALS_DIR.
# In Docker, persist /app/backend/data/creds with a host volume such as
# /opt/omni-gateway/creds. External databases are optional storage backends,
# but Omni Gateway 1.x still requires one worker and one application replica.
# Configure at most one external database. Explicit database failures stop startup
# instead of falling back to local SQLite.
CREDENTIALS_DIR=./backend/data/creds
MONGODB_URI=
MONGODB_DATABASE=omni_gateway
POSTGRESQL_URI=
REDIS_URL=

# Optional environment credential import.
# Paste raw JSON or use the *_B64 variants for base64-encoded JSON.
# CODE_ASSIST_CREDENTIALS_JSON={"token":"...","refresh_token":"...","client_id":"...","client_secret":"...","project_id":"..."}
# CREDENTIALS_JSON={"token":"...","refresh_token":"...","client_id":"...","client_secret":"...","project_id":"..."}

# Optional OAuth client overrides for interactive credential creation.
# Built-in desktop OAuth clients are provided by default; override only when needed.
# Google Antigravity settings can also be configured from the Providers page and stored locally.
# CODE_ASSIST_CLIENT_ID=
# CODE_ASSIST_CLIENT_SECRET=
# ANTIGRAVITY_CLIENT_ID=
# ANTIGRAVITY_CLIENT_SECRET=
# ANTIGRAVITY_USER_AGENT=antigravity/cli/1.0.1 windows/amd64
# ANTIGRAVITY_PAYLOAD_USER_AGENT=antigravity

# Network and upstream endpoints
PROXY=
CODE_ASSIST_ENDPOINT=https://cloudcode-pa.googleapis.com
ANTIGRAVITY_API_URL=https://daily-cloudcode-pa.googleapis.com
GOOGLE_AI_STUDIO_API_URL=https://generativelanguage.googleapis.com
# Grok includes a built-in public OAuth client. xAI Console uses the API endpoint below.
# Override these shared xAI transport settings only when needed.
XAI_API_URL=https://api.x.ai/v1
XAI_OAUTH_ISSUER=https://auth.x.ai
# XAI_CLIENT_ID=
# XAI_USER_AGENT=grok-cli/omni-gateway
OAUTH_URL=https://oauth2.googleapis.com
GOOGLE_APIS_URL=https://www.googleapis.com
RESOURCE_MANAGER_URL=https://cloudresourcemanager.googleapis.com
SERVICE_USAGE_URL=https://serviceusage.googleapis.com
# Required only when enabling Vertex anonymous routing.
VERTEX_ANON_API_KEY=

# Fallback, retry, and health behavior
AUTO_DISABLE=false
AUTO_DISABLE_ERROR_CODES=403
RETRY_429_ENABLED=true
RETRY_429_MAX_RETRIES=5
RETRY_429_INTERVAL=1
SWITCH_CREDENTIAL_ENABLED=true

# Cross-provider routing
# balanced spreads traffic by health and concurrency. priority prefers one
# provider and falls back automatically when it is unavailable or incompatible.
ROUTING_STRATEGY=balanced
PREFERRED_PROVIDER=
UPSTREAM_TIMEOUT_SECONDS=300

# Translation and response shaping
COMPATIBILITY_MODE=false
RETURN_THOUGHTS_TO_FRONTEND=true
STREAM_TO_NONSTREAM=true
ANTI_TRUNCATION_MAX_ATTEMPTS=3

# Context optimization
# Oversized histories are trimmed only at safe user-turn boundaries. System
# instructions, tool definitions, and the configured recent turns are retained.
TOKEN_COMPRESSION_ENABLED=true
TOKEN_COMPRESSION_THRESHOLD=32000
TOKEN_COMPRESSION_TARGET=24000
TOKEN_COMPRESSION_MIN_RECENT_TURNS=4

# Observability
LOG_LEVEL=info
LOG_MAX_MB=10
LOG_BACKUP_COUNT=3
# In Docker, persist /app/backend/data/logs with a host volume such as
# /opt/omni-gateway/logs.
LOG_FILE=./backend/data/logs/omni-gateway.log

# Optional keep-alive ping for platforms that suspend idle services.
KEEPALIVE_URL=
KEEPALIVE_INTERVAL=60
